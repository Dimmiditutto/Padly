# Configurazione comune
APP_NAME=PadelBooking
APP_ENV=development
# Dominio pubblico dell'app, senza slash finale. In locale puoi lasciare localhost.
APP_URL=http://localhost:8000
API_PREFIX=/api
# Origini aggiuntive consentite da CORS, separate da virgole.
CORS_ALLOWED_ORIGINS=
# In produzione l'app non parte se lasci placeholder o valori di default per secret e credenziali admin.
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_EMAIL=replace-with-real-admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
# Dominio cookie opzionale per sessione admin in setup multi-tenant con sottodomini condivisi.
ADMIN_SESSION_COOKIE_DOMAIN=

# Locale/test: il repository puo continuare a usare SQLite.
# Produzione/Railway: sostituisci con la connection string PostgreSQL del servizio Railway.
DATABASE_URL=sqlite:///./padelbooking.db

# Scheduler: tieni true solo sull'istanza designata a eseguire reminder e scadenze.
TIMEZONE=Europe/Rome
SCHEDULER_ENABLED=true
BOOKING_HOLD_MINUTES=15
CANCELLATION_WINDOW_HOURS=24

# SMTP: opzionale in locale/test, richiesto per invii reali in ambienti operativi.
# Usa SMTP_USE_SSL=true con provider SMTPS impliciti come Aruba su porta 465.
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Stripe: richiesto solo se vuoi attivare il provider reale.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Billing SaaS: obbligatorio in produzione se usi il webhook subscription.
STRIPE_BILLING_WEBHOOK_SECRET=

# PayPal: in sandbox usa PAYPAL_ENV=sandbox e PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# In produzione usa PAYPAL_ENV=live e PAYPAL_API_BASE=https://api-m.paypal.com
# Alias legacy supportato: PAYPAL_BASE_URL
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=

# Limite richieste sulle route pubbliche e login admin.
RATE_LIMIT_PER_MINUTE=60

# Control plane SaaS: obbligatorio in produzione per provisioning/sospensione tenant.
PLATFORM_API_KEY=
